# =========================================================================
# CONFIGURATION FOR MOTOV SYSTEM (ROOT ENVIRONMENT FILE TEMPLATE)
# Copy this file to '.env' at the root of the project before running.
# =========================================================================

# --- Server Config (Node Backend) ---
PORT=5000
MONGODB_URI=mongodb://localhost:27017/Motov
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# --- Client Config (Vite React Frontend) ---
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
VITE_API_URL=http://localhost:5000/api

# --- Email SMTP Config (Google Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password_here

# --- Firebase Client Config (for Real Phone OTP) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Firebase Server Config (Firebase Admin SDK) ---
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_KEY_PATH=firebase-key.json
FIREBASE_PROJECT_ID=your_project_id

# --- VNPAY Config ---
VNP_TMNCODE=your_tmn_code_here
VNP_HASHSECRET=your_hash_secret_here
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURNURL=http://localhost:3000/vnpay-return
