# =========================================================================
# MOTOV SYSTEM - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' at the root of the project before running.
# =========================================================================

# --- Server Config (Node Backend) ---
PORT=5000
MONGODB_URI=mongodb://localhost:27017/Motov
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# --- Client Config (Vite React Frontend) ---
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
VITE_API_URL=http://localhost:5000/api

